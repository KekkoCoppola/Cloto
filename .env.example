# GEMINI_API_KEY: Required for Gemini AI API calls.
# This key is loaded SERVER-SIDE only (by server.ts via dotenv).
# It is NEVER injected into the browser bundle — do NOT add the VITE_ prefix.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# PORT: Optional. Port for the Express backend server (default: 4000).
# The Vite dev server on port 3000 proxies /api/* to this port automatically.
PORT=4000

# APP_URL: The public URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="YOUR_APP_URL"
